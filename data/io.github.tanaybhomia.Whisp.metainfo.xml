<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.tanaybhomia.Whisp</id>
  <name>Whisp</name>
  <summary>A minimalist note taking widget</summary>
  <developer_name>Tanay Bhomia</developer_name>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <url type="homepage">https://github.com/tanaybhomia/Whisp</url>
  <url type="bugtracker">https://github.com/tanaybhomia/Whisp/issues</url>
  
  <custom>
    <value key="flathub::theme::primary">#00cccc</value>
    <value key="flathub::theme::secondary">#004252</value>
  </custom>

  <description>
    <p>Whisp is a beautifully simple, gesture-driven note-taking application designed for GNOME.</p>
    <p>Features include:</p>
    <ul>
      <li>Live Markdown formatting (bold, italics, headers, code, lists)</li>
      <li>Swipe navigation between notes</li>
      <li>Searchable note list directly from the header</li>
      <li>Instant saving and Native UI styling</li>
    </ul>
  </description>
  <launchable type="desktop-id">io.github.tanaybhomia.Whisp.desktop</launchable>
</component>
